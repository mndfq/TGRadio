# Copy this file to .env and fill in real values.
# Get API_ID / API_HASH from https://my.telegram.org -> API Development Tools

API_ID=123456
API_HASH=your_api_hash_here

# The phone number of the Telegram ACCOUNT this bot will log in as.
# This is a userbot (needed to join voice chats) — it uses a real
# account session, not a bot token. Include country code, e.g. +15551234567
PHONE=+15551234567

# Channel the bot streams audio from. Username (without @) or numeric ID.
CHANNEL_ID=your_channel_username_or_id

# Your personal Telegram numeric user ID — only this account can use
# /skip, /stop, /shutdown. Get it from @userinfobot on Telegram.
ADMIN_ID=123456789

# Optional overrides:
# SESSION_NAME=tgradio
# CACHE_DIR=cache
